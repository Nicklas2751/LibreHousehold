# Backend API URL for development (mockapi container)
VITE_API_URL=http://localhost

# VITE_AUTHORITY is only needed when backend and frontend run on different ports without a proxy.
# In standard development (Vite proxy + local Spring profile with issuer=http://localhost:5173),
# do NOT set this — the default value window.location.origin is correct.
# VITE_AUTHORITY=http://localhost:5173
