{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"openapi": "rm -rf src/generated-sources/openapi; npx @openapitools/openapi-generator-cli generate -i ../api/openapi.yml -g typescript-fetch -o src/generated-sources/openapi --additional-properties=supportsES6=true,modelPropertyNaming=original",
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
	},
	"devDependencies": {
		"@castlenine/svelte-qrcode": "^2.3.0",
		"@eslint/js": "^10.0.0",
		"@inlang/paraglide-js": "^2.20.2",
		"@openapitools/openapi-generator-cli": "^2.39.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26",
		"@vitest/browser": "^4.1.10",
		"@vitest/browser-playwright": "^4.1.8",
		"daisyui": "^5.6.13",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.2.1"
	},
	"dependencies": {
		"@indaco/svelte-iconoir": "^7.11.1",
		"uuid": "^14.0.1"
	}
}
